<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>amber</id>
    <name>Amber Language</name>
    <vendor>linux_china</vendor>
    <description><![CDATA[
        <p><b>Amber</b> is a JetBrains plugin that provides support for the [Amber](https://amber-lang.com/) language.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <resource-bundle>messages.AmberBundle</resource-bundle>

    <actions>
        <action id="NewAmberFile"
                class="org.mvnsearch.jetbrains.amber.actions.NewAmberFileAction"
                icon="org.mvnsearch.jetbrains.amber.AmberIcons.FILE">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Amber"
                  implementationClass="org.mvnsearch.jetbrains.amber.AmberFileType"
                  fieldName="INSTANCE"
                  language="Amber"
                  extensions="ab"/>
        <lang.parserDefinition language="Amber"
                               implementationClass="org.mvnsearch.jetbrains.amber.AmberParserDefinition"/>
        <lang.syntaxHighlighterFactory language="Amber"
                                       implementationClass="org.mvnsearch.jetbrains.amber.lighter.AmberSyntaxHighlighterFactory"/>
        <lang.braceMatcher language="Amber"
                           implementationClass="org.mvnsearch.jetbrains.amber.misc.AmberBraceMatcher"/>
        <lang.commenter language="Amber"
                        implementationClass="org.mvnsearch.jetbrains.amber.misc.AmberCommenter"/>
        <lang.foldingBuilder language="Amber"
                             implementationClass="org.mvnsearch.jetbrains.amber.fold.AmberFoldingBuilder"/>
        <lang.quoteHandler language="Amber"
                           implementationClass="org.mvnsearch.jetbrains.amber.misc.AmberQuoteHandler"/>
        <annotator language="Amber"
                   implementationClass="org.mvnsearch.jetbrains.amber.lighter.AmberHighlightAnnotator"/>
        <lang.directNavigationProvider
                implementation="org.mvnsearch.jetbrains.amber.navigation.ImportPathRefNavigation"/>
        <lang.namesValidator language="Amber"
                             implementationClass="org.mvnsearch.jetbrains.amber.refactoring.AmberNamesValidator"/>
        <configurationType
                implementation="org.mvnsearch.jetbrains.amber.run.AmberRunConfigurationType"/>
        <runConfigurationProducer
                implementation="org.mvnsearch.jetbrains.amber.run.AmberRunConfigurationProducer"/>
<!--        <lang.documentationProvider language="Amber"-->
<!--                                    implementationClass="org.mvnsearch.jetbrains.amber.documentation.AmberDocumentationProvider"/>-->
        <lang.psiStructureViewFactory language="Amber"
                                      implementationClass="org.mvnsearch.jetbrains.amber.structure.AmberStructureViewFactory"/>
        <typedHandler implementation="org.mvnsearch.jetbrains.amber.misc.AmberTypedHandler"/>
        <codeInsight.parameterNameHints
                language="Amber"
                implementationClass="org.mvnsearch.jetbrains.amber.misc.AmberHintsProvider"/>
        <completion.contributor language="Amber"
                                implementationClass="org.mvnsearch.jetbrains.amber.completion.ImportPathCompletionContributor"/>
        <completion.contributor language="Amber"
                                implementationClass="org.mvnsearch.jetbrains.amber.completion.ImportModuleMemberCompletionContributor"/>
        <completion.contributor language="Amber"
                                implementationClass="org.mvnsearch.jetbrains.amber.completion.MiscCompletionContributor"/>
        <codeInsight.lineMarkerProvider language="Amber"
                                        implementationClass="org.mvnsearch.jetbrains.amber.marker.AmberMainLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Amber"
                                        implementationClass="org.mvnsearch.jetbrains.amber.marker.AmberTestLineMarkerProvider"/>
        <liveTemplateContext contextId="AMBER"
                             implementation="org.mvnsearch.jetbrains.amber.template.AmberTemplateContextType"/>
        <defaultLiveTemplates file="liveTemplates/Amber"/>
        <lang.formatter language="Amber"
                        implementationClass="org.mvnsearch.jetbrains.amber.formatter.AmberFormattingModelBuilder"/>

    </extensions>
</idea-plugin>
